<Application x:Class="Chronos.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Chronos"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ResourceDictionarys/Theme.xaml"/>
                <ResourceDictionary Source="/ResourceDictionarys/Fonts.xaml"/>
                <ResourceDictionary Source="/ResourceDictionarys/Icons.xaml"/>
                <ResourceDictionary Source="/ResourceDictionarys/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
