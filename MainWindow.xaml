<Window x:Class="Chronos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chronos"
        mc:Ignorable="d"
        Title="Chronos" 
        Height="450"
        Width="800"
        MinWidth="600"
        MinHeight="350"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="{DynamicResource Poppins}"
        ResizeMode="CanResize"
        Background="Transparent"
        Icon="/Resources/Icon.ico" Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome
        CaptionHeight="0"
        ResizeBorderThickness="0,0,6,6"
        GlassFrameThickness="0"
        UseAeroCaptionButtons="False" CornerRadius="0,0,0,0"/>
    </WindowChrome.WindowChrome>

    <Grid x:Name="grid_Main">
        <Border x:Name="border_Main" 
                BorderThickness="1"
                Background="{DynamicResource PrimaryBrush}" 
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid x:Name="grid_BorderGrid">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="border_TitleBar"
                        Grid.Row="0"
                        Background="{DynamicResource TertiaryBrush}" 
                        Height="32"
                        MouseLeftButtonDown="Drag">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Path Grid.Column="0" 
                              Data="{DynamicResource Logo}" 
                              Fill="{DynamicResource PrimaryForegroundBrush}" 
                              Width="21" 
                              Height="20" 
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Stretch="Fill" Margin="6,0,6,0"/>

                        <Grid x:Name="grid_AppMenuContainer"
                              Grid.Column="1" Margin="5,5,5,5">
                            <Grid>
                                <Menu VerticalAlignment="Center"
                                      Background="{DynamicResource TertiaryBrush}"
                                      Foreground="{DynamicResource SecondaryForegroundBrush}"
                                      FontFamily="{DynamicResource Poppins}"
                                      FontSize="14" HorizontalAlignment="Left">
                                    <MenuItem Header="File">
                                        <MenuItem x:Name="menuItem_NewWindow" 
                                                  Header="New Window" 
                                                  Click="menuItemClick_File"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <Separator/>
                                        <MenuItem x:Name="menuItem_OpenFile" 
                                                  Header="Open File" 
                                                  Click="menuItemClick_File"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <MenuItem x:Name="menuItem_SaveFile" 
                                                  Header="Save File" 
                                                  Click="menuItemClick_File"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <Separator/>
                                        <MenuItem x:Name="menuItem_Exit" 
                                                  Header="Exit" 
                                                  Click="menuItemClick_File"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                    </MenuItem>

                                    <MenuItem Header="Edit" Margin="5,0,5,0">
                                        <MenuItem x:Name="menuItem_Undo" 
                                                  Header="Undo" 
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <MenuItem x:Name="menuItem_Redo" 
                                                  Header="Redo" 
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <Separator/>
                                        <MenuItem x:Name="menuItem_Cut" 
                                                  Header="Cut" 
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <MenuItem x:Name="menuItem_Copy" 
                                                  Header="Copy" 
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <MenuItem x:Name="menuItem_Paste" 
                                                  Header="Paste" 
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <MenuItem x:Name="menuItem_Delete" 
                                                  Header="Delete" 
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <Separator/>
                                        <MenuItem x:Name="menuItem_SearchOnline" 
                                                  Header="Search Online" 
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                    </MenuItem>

                                    <MenuItem Header="View">

                                        <MenuItem x:Name="menuItem_ToggleSidebar" 
                                                  Header="Toggle Explorer" 
                                                  Click="menuItemClick_View"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <MenuItem x:Name="menuItem_ToggleBottombar" 
                                                  Header="Toggle Status Bar" 
                                                  Click="menuItemClick_View"
                                                  Background="{DynamicResource TertiaryBrush}"
                                                  Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                    </MenuItem>
                                </Menu>
                            </Grid>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Grid.Column="3">

                            <Button x:Name="button_Minimize" 
                                Grid.Column="2" 
                                Height="25" 
                                Width="25" 
                                Style="{DynamicResource RoundedButtonStyle}"
                                Foreground="{DynamicResource SecondaryForegroundBrush}"
                                Background="Transparent" 
                                BorderBrush="Transparent" Margin="3.5,0,0,0" Click="buttonClick_WindowControls">
                                <Path Grid.Column="0" 
                                  Data="{DynamicResource Minimize}" 
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                Width="14" 
                                  HorizontalAlignment="Center"
                                  Height="1.5" 
                                  VerticalAlignment="Center"
                                  Stretch="Fill"/>
                            </Button>
                            
                            <Button x:Name="button_Maximize" 
                                Grid.Column="3" 
                                Height="25" 
                                Width="25"
                                Style="{DynamicResource RoundedButtonStyle}"
                                Foreground="{DynamicResource SecondaryForegroundBrush}"
                                Background="Transparent" 
                                BorderBrush="Transparent" Margin="3.5,0,3.5,0" Click="buttonClick_WindowControls">
                                <Path x:Name="path_Maximize" Grid.Column="0" 
                                  Data="{DynamicResource Maximize}" 
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                  Width="14" 
                                  HorizontalAlignment="Center"
                                  Height="14" 
                                  VerticalAlignment="Center"
                                  Stretch="Fill"/>
                            </Button>

                            <Button x:Name="button_Close" 
                                Grid.Column="4" 
                                Height="25" 
                                Width="25"
                                Style="{DynamicResource RoundedButtonStyle}"
                                Foreground="{DynamicResource SecondaryForegroundBrush}"
                                Background="Transparent" 
                                BorderBrush="Transparent" Click="buttonClick_WindowControls" Margin="0,0,3.5,0">
                                <Path Grid.Column="0" 
                                  Data="{DynamicResource Close}" 
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                  Width="14" 
                                  HorizontalAlignment="Center"
                                  Height="14" 
                                  VerticalAlignment="Center"
                                  Stretch="Fill"/>
                            </Button>

                        </StackPanel>

                    </Grid>
                </Border>

                <Border x:Name="border_ToolBar"
                        Grid.Row="1"
                        Background="{DynamicResource SecondaryBrush}" 
                        Height="32"
                        MouseLeftButtonDown="Drag">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border VerticalAlignment="Top" Background="{DynamicResource BorderBrush}" Height="1" Grid.ColumnSpan="67"/>
                        <Border Background="{DynamicResource BorderBrush}" VerticalAlignment="Bottom" Height="1" Grid.ColumnSpan="67"/>



                        <StackPanel Orientation="Horizontal" Grid.Column="2">
                            <Button x:Name="button_OpenFile" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Margin="5,0,2.5,0" Click="buttonClick_ToolbarControlsLeft">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource OpenFile}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                            </Button>

                            <Button x:Name="button_SaveFile" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="2.5,0,5,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource SaveFile}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                            </Button>
                            <Border Background="{DynamicResource BorderBrush}" Width="1"/>
                            <Button x:Name="button_Cut" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="5,0,2.5,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource Cut}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                            </Button>
                            <Button x:Name="button_Copy" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="2.5,0,2.5,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource Copy}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                            </Button>
                            <Button x:Name="button_Paste" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="2.5,0,2.5,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource Paste}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                            </Button>
                            <Button x:Name="button_Delete" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="2.5,0,5,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource Delete}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                            </Button>
                            <Border Background="{DynamicResource BorderBrush}" Width="1"/>
                            <Button x:Name="button_Undo" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="5,0,2.5,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource Undo}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                            </Button>
                            <Button x:Name="button_Redo" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="2.5,0,5,0">
                                <Path Grid.Column="0" 
                                      Data="{DynamicResource Redo}" 
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"                                    Width="15" 
                                      HorizontalAlignment="Center"
                                      Height="15" 
                                      VerticalAlignment="Center"
                                      Stretch="Fill"/>
                            </Button>
                            <Border Background="{DynamicResource BorderBrush}" Width="1"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Grid.Column="3">
                            <Border Background="{DynamicResource BorderBrush}" Width="1" Grid.RowSpan="67" HorizontalAlignment="Center"/>
                            <Button x:Name="button_ToggleBottombar"
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Margin="5,0,0,0" Click="buttonClick_ToolbarControlsRight">
                                <Path x:Name="path_Bottombar" Grid.Column="0" 
                                      Data="{DynamicResource Bottombar_Disabled}" 
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                    Width="15" 
                                      HorizontalAlignment="Center"
                                      Height="15" 
                                      VerticalAlignment="Center"
                                      Stretch="Fill"/>
                            </Button>

                            <Button x:Name="button_ToggleSidebar"
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                                    BorderBrush="Transparent" Click="buttonClick_ToolbarControlsRight" Margin="5,0,5,0">
                                <Path x:Name="path_Sidebar" Grid.Column="0" 
                                      Data="{DynamicResource Sidebar_Disabled}" 
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                    Width="15" 
                                      HorizontalAlignment="Center"
                                      Height="15" 
                                      VerticalAlignment="Center"
                                      Stretch="Fill"/>
                            </Button>

                            <Button x:Name="button_Settings" 
                                    Height="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Width="25" 
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Margin="0,0,5,0" Click="buttonClick_ToolbarControlsRight">
                                <Path x:Name="path_Settings" Grid.Column="0" 
                                      Data="{DynamicResource Settings}" 
                                      Width="15" 
                                      HorizontalAlignment="Center"
                                      Height="15" 
                                      VerticalAlignment="Center"
                                      Stretch="Fill"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid x:Name="grid_Content"
                      Grid.Row="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="border_Sidebar"
                            Visibility="Collapsed"
                            Grid.Column="0"
                            Background="{DynamicResource TertiaryBrush}" 
                            Width="192">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Border Height="30">
                                <Border.Background>
                                    <SolidColorBrush Color="{DynamicResource TertiaryColor}"/>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" 
                                          Data="{DynamicResource Search}" 
                                          Fill="{DynamicResource SecondaryForegroundBrush}"                                    
                                          Width="15" 
                                          HorizontalAlignment="Center"
                                          Height="15" 
                                          VerticalAlignment="Center"
                                          Stretch="Fill" Margin="7,0,7,0"/>
                                    <TextBox Grid.Column="1"
                                             Background="Transparent"
                                             BorderBrush="Transparent"
                                             BorderThickness="0"
                                             Text="Search" 
                                             CaretBrush="{DynamicResource SecondaryForegroundBrush}"
                                             VerticalAlignment="Center"
                                             Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,7,0"/>

                                    <Border Background="{DynamicResource BorderBrush}" Grid.ColumnSpan="67" VerticalAlignment="Bottom" Height="1"/>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BorderBrush}" Width="1" Grid.RowSpan="67" HorizontalAlignment="Right"/>

                        </Grid>
                    </Border>

                    <avalonEdit:TextEditor
                        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
                        Name="avalonEdit_TextEditor"
                        Background="Transparent"
                        Foreground="{DynamicResource SecondaryForegroundBrush}"
                        ShowLineNumbers="True"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto"
                        FontFamily="Consolas"
                        Padding="0"
                        Grid.Column="1"
                        FontSize="10pt"/>


                </Grid>

                <Border x:Name="border_Bottombar"
                        Visibility="Collapsed"
                        Grid.Row="3"
                        Background="{DynamicResource SecondaryBrush}" 
                        Height="32"
                        MouseLeftButtonDown="Drag">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="{DynamicResource BorderBrush}" VerticalAlignment="Top" Height="1" Grid.ColumnSpan="67"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <Grid x:Name="grid_Splash" Margin="0,484,0,-484" PreviewMouseLeftButtonDown="Drag">
            <Path Grid.Column="0" 
                      Data="{DynamicResource Logo}" 
                      Fill="{DynamicResource PrimaryForegroundBrush}" 
                      Width="176" 
                      Height="175" 
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Stretch="Fill" Margin="6,0,6,0"/>
        </Grid>

    </Grid>
</Window>
