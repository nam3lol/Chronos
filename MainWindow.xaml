<Window x:Class="Chronos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chronos"
        mc:Ignorable="d"
        Title="Chronos" 
        Height="450"
        Width="800"
        MinWidth="600"
        MinHeight="350"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="{DynamicResource Poppins}"
        ResizeMode="CanResize"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Icon="/Resources/app.ico" 
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            ResizeBorderThickness="5"
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False" 
            CornerRadius="0,0,0,0"/>
    </WindowChrome.WindowChrome>

    <Grid x:Name="grid_Main">
        <Border x:Name="border_Main" 
                BorderThickness="1"
                Background="{DynamicResource PrimaryWindowBrush}" 
                BorderBrush="{DynamicResource WindowBorderBrush}">
            <Grid x:Name="grid_BorderGrid">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="border_TitleBar"
                        Grid.Row="0"
                        Background="{DynamicResource TertiaryWindowBrush}" 
                        Height="32"
                        MouseLeftButtonDown="Drag">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Path Grid.Column="0" 
                              Data="{DynamicResource Logo}" 
                              Fill="{DynamicResource PrimaryWindowForegroundBrush}" 
                              Width="21" 
                              Height="20" 
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Stretch="Fill" Margin="6,0,6,0"/>

                        <Grid x:Name="grid_AppMenuContainer"
                              Grid.Column="1" Margin="0,5,5,5">
                            <Grid>
                                <Menu VerticalAlignment="Center"
                                      Background="{DynamicResource TertiaryWindowBrush}"
                                      Foreground="{DynamicResource SecondaryWindowBrush}"
                                      FontFamily="{DynamicResource Poppins}"
                                      FontSize="14" HorizontalAlignment="Left" >
                                    
                                    <MenuItem Header="File"
                                              Style="{DynamicResource TopLevelMenuItem}"
                                              Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}">
                                        <MenuItem x:Name="menuItem_NewWindow"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  Header="New Window"
                                                  Tag="{DynamicResource OpenNew}"
                                                  Click="menuItemClick_File"
                                                  BorderThickness="0"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}">
                                        </MenuItem>
                                        <Separator Style="{DynamicResource MenuItemSeperator}"/>
                                        <MenuItem x:Name="menuItem_OpenFile" 
                                                  Header="Open File"
                                                  BorderThickness="0"
                                                  Tag="{DynamicResource OpenFile}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  Click="menuItemClick_File"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <MenuItem x:Name="menuItem_SaveFile" 
                                                  Header="Save File"
                                                  BorderThickness="0"
                                                  Tag="{DynamicResource SaveFile}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  Click="menuItemClick_File"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <Separator Style="{DynamicResource MenuItemSeperator}"/>
                                        <MenuItem x:Name="menuItem_Exit" 
                                                  Header="Exit"
                                                  BorderThickness="0"
                                                  Tag="{DynamicResource Close}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  Click="menuItemClick_File"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                    </MenuItem>

                                    <MenuItem Header="Edit"
                                              Style="{DynamicResource TopLevelMenuItem}"
                                              Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}">
                                        <MenuItem x:Name="menuItem_Undo" 
                                                  Header="Undo"
                                                  BorderThickness="0"
                                                  Tag="{DynamicResource Undo}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <MenuItem x:Name="menuItem_Redo" 
                                                  Header="Redo"
                                                  Tag="{DynamicResource Redo}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  BorderThickness="0"
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <Separator Style="{DynamicResource MenuItemSeperator}"/>
                                        <MenuItem x:Name="menuItem_Cut" 
                                                  Header="Cut"
                                                  Tag="{DynamicResource Cut}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  BorderThickness="0"
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <MenuItem x:Name="menuItem_Copy" 
                                                  Header="Copy"
                                                  Tag="{DynamicResource Copy}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  BorderThickness="0"
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <MenuItem x:Name="menuItem_Paste" 
                                                  Header="Paste"
                                                  Tag="{DynamicResource Paste}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  BorderThickness="0"
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <MenuItem x:Name="menuItem_Delete" 
                                                  Header="Delete"
                                                  Tag="{DynamicResource Delete}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  BorderThickness="0"
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <Separator Style="{DynamicResource MenuItemSeperator}"/>
                                        <MenuItem x:Name="menuItem_SearchOnline"
                                                  Header="Search Online"
                                                  Tag="{DynamicResource Internet}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  BorderThickness="0"
                                                  Click="menuItemClick_Edit"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                    </MenuItem>

                                    <MenuItem Header="View" 
                                              Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                              Style="{DynamicResource TopLevelMenuItem}">

                                        <MenuItem x:Name="menuItem_ToggleSidebar" 
                                                  Header="Explorer"
                                                  Tag="{DynamicResource Sidebar_Disabled}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  IsCheckable="True"
                                                  BorderThickness="0"
                                                  Click="menuItemClick_View"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}">
                                        </MenuItem>
                                        <MenuItem x:Name="menuItem_ToggleBottombar" 
                                                  Header="Status Bar"
                                                  Tag="{DynamicResource Bottombar_Disabled}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  IsCheckable="True"
                                                  BorderThickness="0"
                                                  Click="menuItemClick_View"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <Separator Style="{DynamicResource MenuItemSeperator}"/>
                                        <MenuItem x:Name="menuItem_ToggleLineNumbers" 
                                                  Header="Line Numbers"
                                                  IsCheckable="True"
                                                  Tag="{DynamicResource Number}"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  BorderThickness="0"
                                                  Click="menuItemClick_View"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                        <Separator Style="{DynamicResource MenuItemSeperator}"/>
                                        <MenuItem x:Name="menuItem_ChangeTheme" 
                                                  Header="Change Theme"
                                                  Style="{DynamicResource SubMenuItem}"
                                                  BorderThickness="0"
                                                  Click="menuItemClick_View"
                                                  Background="{DynamicResource TertiaryMenuItemBackgroundBrush}"
                                                  Foreground="{DynamicResource SecondaryMenuItemForegroundBrush}"
                                                  FontFamily="{DynamicResource Poppins}"/>
                                    </MenuItem>
                                </Menu>
                            </Grid>
                        </Grid>

                        <StackPanel Orientation="Horizontal" 
                                    Grid.Column="3">

                            <Button x:Name="button_Minimize"
                                    Height="25" 
                                    Width="25" 
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    Background="Transparent" 
                                    BorderBrush="Transparent" 
                                    Margin="4,0,2,0" 
                                    Click="buttonClick_WindowControls">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource Minimize}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                
                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="1.5" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                            </Button>

                            <Button x:Name="button_Maximize"
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    Background="Transparent" 
                                    BorderBrush="Transparent" 
                                    Margin="2,0,2,0" 
                                    Click="buttonClick_WindowControls">
                                <Path x:Name="path_Maximize" Grid.Column="0" 
                                    Data="{DynamicResource Maximize}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                  
                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                            </Button>

                            <Button x:Name="button_Close"
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    Background="Transparent" 
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_WindowControls" 
                                    Margin="2,0,4,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource Close}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                  
                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                            </Button>

                        </StackPanel>

                    </Grid>
                </Border>

                <Border x:Name="border_ToolBar"
                        Grid.Row="1"
                        Background="{DynamicResource SecondaryWindowBrush}" 
                        Height="32"
                        MouseLeftButtonDown="Drag">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border VerticalAlignment="Top" Background="{DynamicResource WindowBorderBrush}" Height="1" Grid.ColumnSpan="67"/>
                        <Border Background="{DynamicResource WindowBorderBrush}" VerticalAlignment="Bottom" Height="1" Grid.ColumnSpan="67"/>



                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <Button x:Name="button_OpenFile" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Margin="4,0,2,0" Click="buttonClick_ToolbarControlsLeft">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource OpenFile}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                                <Button.ToolTip>
                                    <ToolTip>
                                        Open file
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>

                            <Button x:Name="button_SaveFile" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="2,0,4,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource SaveFile}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                                <Button.ToolTip>
                                    <ToolTip>
                                        Save file
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                            <Border Background="{DynamicResource WindowBorderBrush}" Width="1"/>
                            <Button x:Name="button_Cut" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="4,0,2,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource Cut}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                                <Button.ToolTip>
                                    <ToolTip>
                                        Cut
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                            <Button x:Name="button_Copy" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="2,0,2,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource Copy}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                                <Button.ToolTip>
                                    <ToolTip>
                                        Copy
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                            <Button x:Name="button_Paste" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="2,0,2,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource Paste}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="16"
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                                <Button.ToolTip>
                                    <ToolTip>
                                        Paste
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                            <Button x:Name="button_Delete" 
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="2,0,4,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource Delete}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                                <Button.ToolTip>
                                    <ToolTip>
                                        Delete
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                            <Border Background="{DynamicResource WindowBorderBrush}" Width="1"/>
                            <Button x:Name="button_Undo"
                                    IsEnabled="False"
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="4,0,2,0">
                                <Path Grid.Column="0" 
                                    Data="{DynamicResource Undo}" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"                                    Width="15" 
                                    HorizontalAlignment="Center"
                                    Height="15" 
                                    VerticalAlignment="Center"
                                    Stretch="Fill"/>
                                <Button.ToolTip>
                                    <ToolTip>
                                        Undo
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                            <Button x:Name="button_Redo"
                                    IsEnabled="False"
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Click="buttonClick_ToolbarControlsLeft" 
                                    Margin="2,0,4,0">
                                <Path Grid.Column="0" 
                                      Data="{DynamicResource Redo}" 
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"                                    Width="15" 
                                      HorizontalAlignment="Center"
                                      Height="15" 
                                      VerticalAlignment="Center"
                                      Stretch="Fill"/>
                                <Button.ToolTip>
                                    <ToolTip>
                                        Redo
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                            <Border Background="{DynamicResource WindowBorderBrush}" Width="1"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Grid.Column="2">

                            <Border Background="{DynamicResource WindowBorderBrush}" Width="1" Grid.RowSpan="67" HorizontalAlignment="Center"/>

                            <Button x:Name="button_ToggleSidebar"
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    BorderBrush="Transparent" Click="buttonClick_ToolbarControlsRight" Margin="4,0,2,0">
                                <Path x:Name="path_Sidebar" Grid.Column="0" 
                                      Data="{DynamicResource Sidebar_Disabled}" 
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                    Width="15" 
                                      HorizontalAlignment="Center"
                                      Height="15" 
                                      VerticalAlignment="Center"
                                      Stretch="Fill"/>
                                <Button.ToolTip>
                                    <ToolTip>
                                        Toggle Explorer
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>

                            <Button x:Name="button_ToggleBottombar"
                                    Height="25" 
                                    Width="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Margin="2,0,2,0" Click="buttonClick_ToolbarControlsRight">
                                <Path x:Name="path_Bottombar" Grid.Column="0" 
                                      Data="{DynamicResource Bottombar_Disabled}" 
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"                                    Width="15" 
                                      HorizontalAlignment="Center"
                                      Height="15" 
                                      VerticalAlignment="Center"
                                      Stretch="Fill"/>
                                <Button.ToolTip>
                                    <ToolTip>
                                        Toggle Statusbar
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>

                            <Button x:Name="button_Settings" 
                                    Height="25"
                                    Style="{DynamicResource RoundedButtonStyle}"
                                    Width="25" 
                                    Background="Transparent"
                                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                    BorderBrush="Transparent" 
                                    Margin="2,0,4,0" Click="buttonClick_ToolbarControlsRight">
                                <Path x:Name="path_Settings" Grid.Column="0" 
                                      Data="{DynamicResource Settings}" 
                                      Width="15" 
                                      HorizontalAlignment="Center"
                                      Height="15" 
                                      VerticalAlignment="Center"
                                      Stretch="Fill"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Button.ToolTip>
                                    <ToolTip>
                                        Open Settings
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>

                        </StackPanel>
                    </Grid>
                </Border>

                <Grid x:Name="grid_Content"
                      Grid.Row="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition 
                            x:Name="SidebarColumn"
                            Width="194"
                            MinWidth="194"
                            MaxWidth="500"/>
                        <ColumnDefinition 
                            x:Name="SplitterColumn"
                            Width="5"/>
                        <ColumnDefinition 
                            x:Name="ContentColumn"
                            Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="border_Sidebar"
                            Visibility="Visible"
                            Grid.Column="0"
                            Background="{DynamicResource TertiaryWindowBrush}">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Height="30" 
                                    Grid.Row="0"
                                    Background="{DynamicResource TertiaryWindowBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="textblock_SidebarTitle"
                                               Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0"
                                               FontSize="12"
                                               FontFamily="{DynamicResource Poppins}"
                                               Foreground="{DynamicResource SecondaryWindowForegroundBrush}"
                                               Text="Explorer"/>


                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource WindowBorderBrush}" 
                                    Width="1" 
                                    Grid.RowSpan="67" 
                                    HorizontalAlignment="Right"/>

                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  Width="5"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeBehavior="PreviousAndNext"
                                  ResizeDirection="Columns"
                                  Background="Transparent"/>

                    <avalonEdit:TextEditor
                        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
                        Name="avalonEdit_TextEditor"
                        Background="{DynamicResource EditorBackgroundBrush}"
                        Foreground="{DynamicResource EditorForegroundBrush}"
                        LineNumbersForeground="{DynamicResource EditorLineNumbersForegroundBrush}"
                        ShowLineNumbers="True"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto"
                        AllowDrop="True"
                        FontFamily="Consolas"
                        Grid.Column="2"
                        FontSize="10pt">
                    </avalonEdit:TextEditor>
                </Grid>

                <Border x:Name="border_Bottombar"
                        Visibility="Collapsed"
                        Grid.Row="3"
                        Background="{DynamicResource SecondaryWindowBrush}" 
                        Height="32"
                        MouseLeftButtonDown="Drag">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="{DynamicResource WindowBorderBrush}" VerticalAlignment="Top" Height="1" Grid.ColumnSpan="67"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
                <Grid x:Name="grid_Splash" Margin="0,484,0,-484" PreviewMouseLeftButtonDown="Drag">
            <Path Grid.Column="0" 
                      Data="{DynamicResource Logo}" 
                      Fill="{DynamicResource PrimaryWindowForegroundBrush}" 
                      Width="176" 
                      Height="175" 
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Stretch="Fill" Margin="6,0,6,0"/>
        </Grid>
    </Grid>
</Window>
