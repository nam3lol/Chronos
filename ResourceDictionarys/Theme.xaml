<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Base colors -->
    <Color x:Key="AccentColor">#3B82F6</Color>
    <Color x:Key="PrimaryColor">#181818</Color>
    <Color x:Key="SecondaryColor">#1E1E1E</Color>
    <Color x:Key="TertiaryColor">#1B1B1B</Color>
    <Color x:Key="PrimaryForegroundColor">#FFFFFF</Color>
    <Color x:Key="SecondaryForegroundColor">#E1E1E1</Color>
    <Color x:Key="TertiaryForegroundColor">#C8C8C8</Color>
    <Color x:Key="BorderColor">#2d2d2d</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AccentBrush"
         Color="{DynamicResource AccentColor}" />

    <SolidColorBrush x:Key="PrimaryBrush"
         Color="{DynamicResource PrimaryColor}" />

    <SolidColorBrush x:Key="SecondaryBrush"
         Color="{DynamicResource SecondaryColor}" />

    <SolidColorBrush x:Key="TertiaryBrush"
     Color="{DynamicResource TertiaryColor}" />

    <SolidColorBrush x:Key="PrimaryForegroundBrush"
         Color="{DynamicResource PrimaryForegroundColor}" />

    <SolidColorBrush x:Key="SecondaryForegroundBrush"
         Color="{DynamicResource SecondaryForegroundColor}" />

    <SolidColorBrush x:Key="TertiaryForegroundBrush"
         Color="{DynamicResource TertiaryForegroundColor}" />

    <SolidColorBrush x:Key="BorderBrush"
         Color="{DynamicResource BorderColor}" />
    
</ResourceDictionary>