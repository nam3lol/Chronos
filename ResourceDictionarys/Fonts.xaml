<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Interface fonts -->
    <FontFamily x:Key="Poppins">pack://application:,,,/Resources/Fonts/Interface/#Poppins</FontFamily>

    <!-- Code fonts -->
    <FontFamily x:Key="FiraCode">pack://application:,,,/Resources/Fonts/Code/#FiraCode</FontFamily>
    <FontFamily x:Key="FiraCode_Italic">pack://application:,,,/Resources/Fonts/Code/#FiraCode_Italic</FontFamily>

    <FontFamily x:Key="JetBrainsMono">pack://application:,,,/Resources/Fonts/Code/#JetBrainsMono</FontFamily>
    <FontFamily x:Key="JetBrainsMono_Italic">pack://application:,,,/Resources/Fonts/Code/#JetBrainsMono_Italic</FontFamily>


</ResourceDictionary>